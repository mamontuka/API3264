# =================================================================
# FreeQwenApi Proxy - Environment Variables
# Copy this file to .env and edit as needed
# =================================================================

# 🔥 Server settings
PORT=3264
HOST=10.32.64.2

# 🔥 Browser auth settings
CHROME_USER_DATA=/root/ai/core/qwen/api3264/profile

CHROMIUM_EXECUTABLE_PATH=/usr/lib/chromium/chromium
CHROMIUM_ARGS=--no-sandbox,--no-first-run,--no-default-browser-check,--disable-features=TranslateUI
CHROMIUM_IGNORE_DEFAULT_ARGS=--enable-automation
CHROME_VIEWPORT_WIDTH=1920
CHROME_VIEWPORT_HEIGHT=1080

# 🔥 Qwen API settings
QWEN_BASE_URL=https://chat.qwen.ai

# 🔥 Default model
DEFAULT_MODEL=qwen3.5-max

# =================================================================
# Qwen API: Model behavior for parent_id handling defaults override
# =================================================================
# Models that REQUIRE explicit parent_id for linear conversation history
# (comma-separated, no spaces)
QWEN_MODELS_REQUIRING_PARENT_ID=qwen3.7-max,qwen3.7-max-preview,qwen3.7-plus,qwen3.7-plus-preview,qwen3.6-plus,qwen3.6-max,qwen3.6-max-preview,qwen3.5-plus,qwen3.5-max,qwen3.5-max-2026-03-08,qwen3.5-flash,qwen3-coder-plus,qwen3-max

# Models that work correctly WITH parent_id=None (auto-build history inside chat_id)
QWEN_MODELS_WITHOUT_PARENT_ID=

# 🔥 Logging
# Set to true for detailed debug logs (production: false)
DEBUG_LOGGING=false

# 🔥 OpenWebUI integration
# Modes: stable (default), per_request, smart
# - stable: one chat per user per hour (continue dialogue)
# - per_request: new chat for every request
# - smart: new chat only when X-New-Chat header is present
OPENWEBUI_CHAT_ID_MODE=smart

# Header name for OpenWebUI user ID (usually doesn't need changing)
OPENWEBUI_USER_ID_HEADER=x-openwebui-user-id

# 🔥 PostgreSQL for OpenWebUI (optional, for auto chat binding)
# Set OPENWEBUI_DB_ENABLED=false to disble database lookup
OPENWEBUI_DB_ENABLED=true
OPENWEBUI_DB_HOST=10.32.64.1
OPENWEBUI_DB_PORT=5432
OPENWEBUI_DB_NAME=openwebui
OPENWEBUI_DB_USER=openwebui
OPENWEBUI_DB_PASSWORD=openwebui
OPENWEBUI_DB_CONNECT_TIMEOUT=5
# 🔥 PostgreSQL SSL mode
# Options: disable, allow, prefer, require, verify-ca, verify-full
OPENWEBUI_DB_SSL_MODE=disable

# 🔥 POSTRGES AUTO MIGRATION
# Select: true, false
ENABLE_AUTO_MIGRATION=true

# 🔥 Chat State Storage Backend
# Options: file, postgres
CHAT_STATE_BACKEND=postgres

# 🔥 Chat State PostgreSQL
# Used only if CHAT_STATE_BACKEND=postgres
CHAT_STATE_DB_HOST=10.32.64.1
CHAT_STATE_DB_PORT=5432
CHAT_STATE_DB_NAME=api3264_chat_state
CHAT_STATE_DB_USER=freeqwenapi
CHAT_STATE_DB_PASSWORD=freeqwenapi
CHAT_STATE_DB_TABLE=chat_mappings
# Chat State Database Pool Settings
CHAT_STATE_DB_POOL_MIN=2
CHAT_STATE_DB_POOL_MAX=10

# 🔥 Token Storage Backend
# Options: file, postgres
TOKEN_STORAGE_BACKEND=postgres

# Used only if TOKEN_STORAGE_BACKEND=postgres
TOKEN_DB_HOST=10.32.64.1
TOKEN_DB_PORT=5432
TOKEN_DB_NAME=api3264_tokens
TOKEN_DB_USER=freeqwenapi
TOKEN_DB_PASSWORD=freeqwenapi
TOKEN_DB_TABLE=tokens
# Options: disable, allow, prefer, require, verify-ca, verify-full
TOKEN_DB_SSL_MODE=disable
# Token Database Pool Settings
TOKEN_DB_POOL_MIN=2
TOKEN_DB_POOL_MAX=10

# Sync delay settings (in seconds)
# Reduce to 0.5 if the API responds faster, or increase under load
# For debugging, you can temporarily disable delays by set to 0 (zero)
PARENT_ID_UPDATE_DELAY=1.5
TOOL_CALL_SYNC_DELAY=1.5

# 🔥 HTTP client settings
HTTP_TIMEOUT=900.0
HTTP_FOLLOW_REDIRECTS=true

# 🔥 Error Hints Configuration
# Enable or disable error hints in API responses
# Options: true, false, 1, 0, yes, no
ERROR_HINTS_ENABLED=false

# 🔥 ERROR Messages Templates
#ERR_RATE_LIMIT_MSG= EN: Request limit exceeded. Service temporarily unavailable.\n RU: Лимит запросов исчерпан. Сервис временно недоступен.\n UA: Ліміт запитів вичерпано. Сервіс тимчасово недоступний.\n
#ERR_RATE_LIMIT_HINT= EN: Try again in a few minutes.\n RU: Попробуйте повторить запрос через несколько минут.\n UA: Спробуйте повторити запит через кілька хвилин.\n

#ERR_CHAT_LOCKED_MSG= EN: Chat is busy processing a previous message.\n RU: Чат занят обработкой предыдущего сообщения.\n UA: Чат зайнятий обробкою попереднього повідомлення.\n
#ERR_CHAT_LOCKED_HINT= EN: Wait for the current operation to complete and retry.\n RU: Подождите завершения текущей операции и повторите запрос.\n UA: Дочекайтеся завершення поточної операції та повторіть запит.\n

#ERR_AUTH_FAILED_MSG= EN: Authentication error on uplink server.\n RU: Ошибка аутентификации на вышестоящем сервере.\n UA: Помилка аутентифікації на вищому сервері.\n
#ERR_AUTH_FAILED_HINT= EN: Administration has been notified and is taking action.\n RU: Администрация извещена и принимает меры.\n UA: Адміністрація повідомлена та вживає заходів.\n

#ERR_MODEL_OVERLOADED_MSG= EN: Model is overloaded. Service is experiencing high load.\n RU: Модель перегружена. Сервис испытывает высокую нагрузку.\n UA: Модель перевантажена. Сервіс зазнає високого навантаження.\n
#ERR_MODEL_OVERLOADED_HINT= EN: Retry later or select a different model.\n RU: Попробуйте повторить запрос позже или выберите другую модель.\n UA: Спробуйте повторити запит пізніше або оберіть іншу модель.\n

#ERR_INVALID_REQUEST_MSG= EN: Invalid request.\n RU: Некорректный запрос.\n UA: Некоректний запит.\n
#ERR_INVALID_REQUEST_HINT= EN: Check request parameters (model, parent_id, message format).\n RU: Проверьте параметры запроса (модель, parent_id, формат сообщения).\n UA: Перевірте параметри запиту (модель, parent_id, формат повідомлення).\n

#ERR_CONTEXT_LENGTH_MSG= EN: Context length exceeds the limit of {max_len} tokens.\n RU: Длина контекста превышает лимит в {max_len} токенов.\n UA: Довжина контексту перевищує ліміт у {max_len} токенів.\n
#ERR_CONTEXT_LENGTH_HINT= EN: Shorten your message, clear history, or start a new chat.\n RU: Сократите сообщение, очистите историю или начните новый чат.\n UA: Скоротіть повідомлення, очистіть історію або почніть новий чат.\n

#ERR_INTERNAL_MSG= EN: Internal error on uplink server side.\n RU: Внутренняя ошибка на стороне вышестоящего сервера.\n UA: Внутрішня помилка на стороні вищого сервера.\n
#ERR_INTERNAL_HINT= EN: Administration has been notified and is taking action. Retry in a minute.\n RU: Администрация извещена и принимает меры. Попробуйте повторить запрос через минуту.\n UA: Адміністрація повідомлена та вживає заходів. Спробуйте повторити запит через хвилину.\n

#ERR_TIMEOUT_MSG= EN: Response timeout or connection error.\n RU: Превышено время ожидания ответа или ошибка соединения.\n UA: Перевищено час очікування відповіді або помилка з'єднання.\n
#ERR_TIMEOUT_HINT= EN: Try again in a few minutes.\n RU: Попробуйте снова через несколько минут.\n UA: Спробуйте знову через кілька хвилин.\n

#ERR_UNKNOWN_MSG= EN: An error occurred while processing the request.\n RU: Произошла ошибка при обработке запроса.\n UA: Сталася помилка під час обробки запиту.\n
#ERR_UNKNOWN_HINT= EN: Details are available for administrators in server logs.\n RU: Подробности доступны администрации в логах сервера.\n UA: Подробиці доступні адміністрації в логах сервера.\n

