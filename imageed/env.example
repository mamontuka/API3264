# ==========================================
# API & MODEL SETTINGS
# ==========================================
QWEN_API_URL=http://10.32.64.2:3264/api/chat/completions
QWEN_MODEL=qwen3.6-plus

# ==========================================
# AUTH & TOKENS
# ==========================================
TOKENS_FILE_PATH=/root/ai/core/qwen/api3264/session/tokens.json
CACHE_TTL=300

# ==========================================
# NETWORK & HOSTS
# ==========================================
# Current instance IP address in netns
INSTANCE_IP=10.32.64.2

# Chrome Debug Port (inside container/netns)
CHROME_DEBUG_PORT_INTERNAL=9222
# Port, what kind socat bounce outside netns
CHROME_DEBUG_PORT_EXTERNAL=9223

# Flask Server
FLASK_HOST=10.32.64.2
FLASK_PORT=7264

# ==========================================
# RUNTIME & PATHS (for run.sh)
# ==========================================
INSTANCE_NUM=3264
BASE_DIR=/root/ai/core/qwen/api${INSTANCE_NUM}
PROFILE_DIR=${BASE_DIR}/profile
CHROME_BIN=/usr/lib/chromium/chromium
DISPLAY_NUM=:${INSTANCE_NUM}
NETNS_NAME=ns-${INSTANCE_NUM}

# Paths for Python script
SCRIPT_DIR=${BASE_DIR}/imageed
VENV_PYTHON=${SCRIPT_DIR}/imageed-venv/bin/python3
SCRIPT_PATH=${SCRIPT_DIR}/imageed.py

# ==========================================
# BEHAVIOR & TIMEOUTS
# ==========================================
DEBUG_MODE=false
TIMEOUT_IMAGE_EXTRACTION=360
REQUEST_TIMEOUT=600
DRIVER_CONNECT_TIMEOUT=60
PAGE_LOAD_TIMEOUT=60

# Color output in logs (true/false)
COLOR_LOGS=false
